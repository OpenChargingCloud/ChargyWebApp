{
  "name": "chargytransparenzsoftware",
  "version": "1.4.7",
  "description": "Chargy ist eine Transparenzsoftware für das Eichrecht in der Elektromobilität womit Endkunden die korrekte Messung und Abrechnung von Ladevorgängen überprüfen können.",
  "author": "GraphDefined GmbH <achim.friedland@graphdefined.com>",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/OpenChargingCloud/ChargyDesktopApp",
  "repository": "https://github.com/OpenChargingCloud/ChargyDesktopApp",
  "main": "build/chargyWebApp-bundle.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf ./build",
    "sbom": "cyclonedx-npm --output-format json --output-file sbom.json",
    "build": "npm run clean && npm run sbom && webpack --config webpack.config.cjs",
    "build:production": "npm run clean && npm run sbom && webpack --config webpack.config.cjs --mode production",
    "start": "webpack serve --open",
    "test": "vitest run --config tests/vitest.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:typecheck": "tsc -p tests/tsconfig.json --noEmit"
  },
  "keywords": [
    "Chargy",
    "Transparency",
    "Transparency Software",
    "Transparenz",
    "Transparenzsoftware",
    "Eichrecht",
    "Calibration Law",
    "Elektromobilität",
    "electromobility",
    "E-Mobilität",
    "E-Mobility",
    "Ladestationen",
    "charging stations",
    "EU MID",
    "EU AFIR",
    "Digital Certificate of Conformity",
    "DCoC",
    "Digital Calibration Certificate",
    "DCC"
  ],
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@oozcitak/dom": "^1.15.10",
    "@types/elliptic": "^6.4.18",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.6.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.7",
    "jpeg-js": "^0.4.4",
    "mini-css-extract-plugin": "^2.10.2",
    "pngjs": "^7.0.0",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "webpack": "^5.108.1",
    "webpack-cli": "^7.1.0",
    "webpack-dev-server": "^5.2.5"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@open-charging-cloud/chargy-core": "^0.9.0",
    "asn1.js": "^5.4.1",
    "base32-decode": "^1.0.0",
    "buffer": "^6.0.3",
    "chart.js": "^4.5.1",
    "decimal.js": "^10.6.0",
    "elliptic": "^6.6.1",
    "leaflet": "^1.9.4",
    "leaflet.awesome-markers": "^2.0.5",
    "moment": "^2.30.1",
    "path-browserify": "^1.0.1",
    "pdfjs-dist": "^6.0.227",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "url": "^0.11.4",
    "uuid": "^14.0.1",
    "vm-browserify": "^1.1.2"
  },
  "overrides": {
    "sockjs": {
      "uuid": "^11.1.1"
    }
  }
}
